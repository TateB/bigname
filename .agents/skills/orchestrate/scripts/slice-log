#!/usr/bin/env python3
"""Append a slice-log event to .agents/state/slices.jsonl.

Usage:
    ./.agents/skills/orchestrate/scripts/slice-log '<json-object>'

Accepts one JSON-object argument. Rejects unknown statuses. Auto-stamps
`ts` (UTC, ISO 8601, Z-terminated) overriding any caller value. Appends one
compact JSON line in canonical field order.

Exit codes:
    0  appended
    2  validation error (message on stderr, log untouched)
"""

import json
import sys
from datetime import datetime, timezone
from pathlib import Path

VALID_STATUSES = ("picked", "in_flight", "completed", "blocked")
FIELD_ORDER = ("slice_id", "status", "ts", "owned_paths", "subagent", "notes")
LOG_RELATIVE = Path(".agents/state/slices.jsonl")


def repo_root() -> Path:
    here = Path(__file__).resolve()
    for parent in here.parents:
        if (parent / ".agents").is_dir():
            return parent
    return Path.cwd()


def fail(msg: str) -> "NoReturn":
    sys.stderr.write(f"slice-log: {msg}\n")
    sys.exit(2)


def main() -> int:
    if len(sys.argv) != 2:
        fail(f"expected one JSON argument; got {len(sys.argv) - 1}")

    try:
        event = json.loads(sys.argv[1])
    except json.JSONDecodeError as exc:
        fail(f"invalid JSON: {exc}")

    if not isinstance(event, dict):
        fail("event must be a JSON object")

    slice_id = event.get("slice_id")
    if not isinstance(slice_id, str) or not slice_id:
        fail("missing or empty 'slice_id'")

    status = event.get("status")
    if status not in VALID_STATUSES:
        fail(f"invalid 'status' {status!r}; expected one of {list(VALID_STATUSES)}")

    event["ts"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

    ordered = {k: event[k] for k in FIELD_ORDER if k in event}
    for k, v in event.items():
        if k not in ordered:
            ordered[k] = v

    target = repo_root() / LOG_RELATIVE
    target.parent.mkdir(parents=True, exist_ok=True)

    line = json.dumps(ordered, separators=(",", ":"), ensure_ascii=False)
    with target.open("a", encoding="utf-8") as handle:
        handle.write(line + "\n")

    sys.stdout.write(line + "\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
